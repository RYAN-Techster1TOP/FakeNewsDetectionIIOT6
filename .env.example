# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/docs/drivers/pymongo/current/
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# Flask Secret Key for session management
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Admin Account (used during initial setup with create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password_here

# GNews API Key for real-time news verification
# Get this from: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here
